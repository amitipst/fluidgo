# .env.prod — Production environment variables for EC2
# NEVER commit this file. Set values directly on the server.
# Copy this template: cp .env.prod.example .env.prod && nano .env.prod

# ── Database ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_strong_random_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_64_char_hex_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ollama model ───────────────────────────────────────────────────────────────
# phi3:mini  = 4GB RAM  → use on t3.large (8GB)
# mistral:7b = 8GB RAM  → use on r6i.large (16GB)
OLLAMA_MODEL=phi3:mini

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
# Replace with your actual domain
CORS_ORIGINS=https://dsr.fluidpro.in,https://www.dsr.fluidpro.in
