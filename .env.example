# fluidGo Environment Variables
# Copy this file to .env and fill in values before running docker compose up

# ── Database ──────────────────────────────────────────
DB_PASSWORD=fluidgo_dev_2026

# ── Auth ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ollama ────────────────────────────────────────────
# phi3:mini  = 4GB RAM  (use on t3.medium or low-RAM dev machine)
# mistral:7b = 8GB RAM  (use on t3.large — better BANT analysis)
OLLAMA_MODEL=phi3:mini

# ── App ───────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── DO NOT COMMIT .env — only .env.example goes to git ─
